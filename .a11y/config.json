{
  "$schema": "https://schema.a11y-reviewer.lilly.internal/v1",
  "version": "1.0.0",
  "a11yReviewerVersion": "1.0.0",
  "wcagLevel": "AA",
  "wcagVersion": "2.2",
  "strictMode": true,
  "rules": {
    "jsx-a11y/img-redundant-alt": {
      "enabled": true,
      "severity": "warning"
    },
    "jsx-a11y/aria-role": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/aria-props": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/aria-unsupported-elements": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/aria-proptypes": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/role-has-required-aria-props": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/role-supports-aria-props": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/alt-text": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/anchor-has-content": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/anchor-is-valid": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/aria-activedescendant-has-tabindex": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/click-events-have-key-events": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/heading-has-content": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/html-has-lang": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/iframe-has-title": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/interactive-supports-focus": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/label-has-associated-control": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/media-has-caption": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/mouse-events-have-key-events": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/no-access-key": {
      "enabled": true,
      "severity": "warning"
    },
    "jsx-a11y/no-autofocus": {
      "enabled": true,
      "severity": "warning"
    },
    "jsx-a11y/no-distracting-elements": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/no-interactive-element-to-noninteractive-role": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/no-noninteractive-element-interactions": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/no-noninteractive-element-to-interactive-role": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/no-noninteractive-tabindex": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/no-redundant-roles": {
      "enabled": true,
      "severity": "warning"
    },
    "jsx-a11y/no-static-element-interactions": {
      "enabled": true,
      "severity": "error"
    },
    "jsx-a11y/scope": {
      "enabled": true,
      "severity": "warning"
    },
    "dom-focus-outline-removal": {
      "enabled": true,
      "severity": "error"
    },
    "dom-div-as-button": {
      "enabled": true,
      "severity": "error"
    },
    "dom-missing-keyboard-handlers": {
      "enabled": true,
      "severity": "error"
    },
    "dom-positive-tabindex": {
      "enabled": true,
      "severity": "error"
    },
    "dom-autoplay-media": {
      "enabled": true,
      "severity": "warning"
    },
    "dom-input-missing-label": {
      "enabled": true,
      "severity": "error"
    },
    "dom-missing-aria-live": {
      "enabled": true,
      "severity": "warning"
    },
    "dom-click-without-keyboard": {
      "enabled": true,
      "severity": "error"
    },
    "dom-unsafe-html-injection": {
      "enabled": true,
      "severity": "error"
    },
    "dom-custom-component-accessibility": {
      "enabled": true,
      "severity": "error"
    },
    "html-missing-lang": {
      "enabled": true,
      "severity": "error"
    },
    "html-missing-title": {
      "enabled": true,
      "severity": "error"
    },
    "html-img-missing-alt": {
      "enabled": true,
      "severity": "error"
    },
    "html-input-missing-label": {
      "enabled": true,
      "severity": "error"
    },
    "html-button-missing-accessible-name": {
      "enabled": true,
      "severity": "error"
    },
    "html-link-missing-accessible-name": {
      "enabled": true,
      "severity": "error"
    },
    "html-iframe-missing-title": {
      "enabled": true,
      "severity": "error"
    },
    "html-div-as-button": {
      "enabled": true,
      "severity": "error"
    },
    "html-positive-tabindex": {
      "enabled": true,
      "severity": "error"
    },
    "html-table-missing-structure": {
      "enabled": true,
      "severity": "error"
    },
    "html-missing-main-landmark": {
      "enabled": true,
      "severity": "warning"
    },
    "html-deprecated-marquee": {
      "enabled": true,
      "severity": "error"
    },
    "html-media-missing-captions": {
      "enabled": true,
      "severity": "error"
    },
    "html-link-new-tab-warning": {
      "enabled": true,
      "severity": "warning"
    },
    "html-heading-hierarchy": {
      "enabled": true,
      "severity": "warning"
    },
    "html-fieldset-missing-legend": {
      "enabled": true,
      "severity": "error"
    },
    "html-duplicate-id": {
      "enabled": true,
      "severity": "error"
    },
    "css-missing-focus-styles": {
      "enabled": true,
      "severity": "error"
    },
    "css-focus-outline-none": {
      "enabled": true,
      "severity": "error"
    },
    "css-insufficient-focus-indicator": {
      "enabled": true,
      "severity": "error"
    },
    "css-hover-only-interaction": {
      "enabled": true,
      "severity": "error"
    },
    "css-low-contrast": {
      "enabled": true,
      "severity": "error"
    },
    "css-text-transparent": {
      "enabled": true,
      "severity": "error"
    },
    "css-motion-without-reduced-motion": {
      "enabled": true,
      "severity": "warning"
    },
    "css-font-size-too-small": {
      "enabled": true,
      "severity": "warning"
    },
    "css-viewport-font-sizing": {
      "enabled": true,
      "severity": "warning"
    },
    "css-touch-target-too-small": {
      "enabled": true,
      "severity": "error"
    },
    "css-text-indent-hiding": {
      "enabled": true,
      "severity": "warning"
    },
    "css-restrictive-text-spacing": {
      "enabled": true,
      "severity": "warning"
    },
    "css-overflow-hidden-on-text": {
      "enabled": true,
      "severity": "error"
    },
    "css-pointer-events-none": {
      "enabled": true,
      "severity": "error"
    },
    "css-all-caps-text": {
      "enabled": true,
      "severity": "warning"
    },
    "css-text-justify": {
      "enabled": true,
      "severity": "warning"
    },
    "general-missing-h1": {
      "enabled": true,
      "severity": "error"
    },
    "general-link-non-descriptive": {
      "enabled": true,
      "severity": "warning"
    },
    "general-aria-labelledby-invalid": {
      "enabled": true,
      "severity": "error"
    },
    "general-duplicate-id": {
      "enabled": true,
      "severity": "error"
    }
  },
  "failureThresholds": {
    "error": 0,
    "warning": 10
  },
  "ignore": [
    "**/*.test.{js,jsx,ts,tsx}",
    "**/*.stories.{js,jsx,ts,tsx}",
    "**/*.spec.{js,jsx,ts,tsx}",
    "node_modules/**",
    "dist/**",
    "build/**",
    ".git/**"
  ]
}
